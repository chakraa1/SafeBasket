# SafeBasket backend configuration (all optional).
# The service runs fully offline with NONE of these set.

# --- Optional LLM layer (enables the richer LangChain agent narrative) ---
# OPENAI_API_KEY=sk-...
# SAFEBASKET_LLM_MODEL=gpt-4o-mini

# --- Optional conditional web research ---
# SAFEBASKET_ENABLE_WEB_SEARCH=true
# TAVILY_API_KEY=tvly-...

# --- Optional LangSmith tracing (observability; works on the free no-LLM tier) ---
# Get a free key at https://smith.langchain.com (see docs/observability.md).
# LANGSMITH_API_KEY=ls-...      # LANGCHAIN_API_KEY also accepted
# LANGCHAIN_PROJECT=safebasket

# --- Commercial API mode ---
# Comma-separated keys accepted on the X-API-Key header for the metered tier.
# SAFEBASKET_API_KEYS=demo-key-1,demo-key-2

# --- Embeddings (upgrade requires: pip install -r requirements-ml.txt) ---
# SAFEBASKET_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- CORS ---
# SAFEBASKET_CORS_ORIGINS=http://localhost:5173
